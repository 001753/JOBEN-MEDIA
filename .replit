modules = ["web", "bash", "nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
DATABASE_CLIENT = "sqlite"
DATABASE_FILENAME = ".tmp/data.db"
HOST = "0.0.0.0"
NEXTJS_REVALIDATION_URL = "https://90c15b7c-85c2-4da6-91fb-ae5554d49bb1-00-1jbfodvy8t9l.sisko.replit.dev/api/revalidate"
NODE_ENV = "development"
PORT = "3001"
PUBLIC_URL = "https://90c15b7c-85c2-4da6-91fb-ae5554d49bb1-00-1jbfodvy8t9l.sisko.replit.dev:3001"
R2_BUCKET_NAME = "joben-news"
R2_ENDPOINT = "https://6ffcdac7c1cf3d08b80450851f6646a3.r2.cloudflarestorage.com"
R2_PUBLIC_URL = "https://pub-eb6a0f12e3b748628e7fb3494cb105a4.r2.dev"
STRAPI_API_URL = "http://localhost:3001"
NEXT_PUBLIC_SITE_URL = "https://news.jobenapp.cloud"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start CMS"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start CMS"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run develop"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80
