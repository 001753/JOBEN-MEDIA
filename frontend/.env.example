# ============================================================
# JOBEN NEWS — Next.js Frontend
# Salin file ini menjadi .env.local (dev) atau isi langsung
# di Environment Variables cPanel (production)
# JANGAN commit file .env / .env.local ke GitHub
# ============================================================

# URL Strapi CMS yang bisa diakses publik (server-side fetch)
STRAPI_API_URL=https://cms.news.jobenapp.cloud

# API Token dari Strapi Admin > Settings > API Tokens
# Buat dengan permission "Read-only" (cukup untuk fetch artikel/kategori/dsb)
STRAPI_API_TOKEN=

# Harus SAMA PERSIS dengan REVALIDATION_SECRET di .env Strapi
REVALIDATION_SECRET=

# URL publik frontend (dipakai untuk sitemap.xml, canonical URL, dsb)
NEXT_PUBLIC_SITE_URL=https://news.jobenapp.cloud

# Google Analytics 4 Measurement ID (opsional, kosongkan jika belum ada)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

NODE_ENV=production
