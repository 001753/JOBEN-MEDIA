# ============================================================
# JOBEN NEWS — Strapi .env (SIAP PAKAI)
# !! JANGAN commit file ini ke GitHub !!
# !! Pastikan .env ada di dalam .gitignore !!
# Salin seluruh isi file ini ke file .env di root project Strapi
# ============================================================

# ------------------------------------------------------------
# DATABASE — PostgreSQL cPanel
# Di-parse dari DATABASE_URL
# ------------------------------------------------------------

DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=smknwon2_jobennews_db
DATABASE_USERNAME=smknwon2_jobennews_user
DATABASE_PASSWORD=Benaya13***
DATABASE_SSL=false

# ------------------------------------------------------------
# CLOUDFLARE R2 — Media Storage
#
# ⚠️  PERLU DIKONFIRMASI:
# R2_ACCESS_KEY_ID di bawah (6ffcdac7c1cf3d08b80450851f6646a3)
# terlihat sama dengan Cloudflare Account ID Anda.
# Pastikan ini benar-benar nilai "Access Key ID" dari halaman
# API Token R2, bukan Account ID.
#
# Cara verifikasi:
#   Cloudflare Dashboard → R2 → Manage R2 API Tokens
#   → Klik token yang ada → lihat kolom "Access Key ID"
#   Jika nilainya BERBEDA dari yang di bawah, update nilainya.
#   Jika nilainya SAMA, berarti sudah benar.
# ------------------------------------------------------------

R2_ACCESS_KEY_ID=6ffcdac7c1cf3d08b80450851f6646a3
R2_SECRET_ACCESS_KEY=ef97ba1eHdpkoMhgEhjrGf6kS7s4Jk5YSiBM898da835fa1ba943cc816ac6536
R2_ENDPOINT=https://6ffcdac7c1cf3d08b80450851f6646a3.r2.cloudflarestorage.com
R2_BUCKET_NAME=joben-news
R2_PUBLIC_URL=https://pub-eb6a0f12e3b748628e7fb3494cb105a4.r2.dev

# ------------------------------------------------------------
# STRAPI SECURITY KEYS
# Di-generate otomatis saat build Strapi dimulai di Replit.
# Jangan diisi manual — biarkan kosong sampai proses build.
# ------------------------------------------------------------

APP_KEYS=
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
JWT_SECRET=
TRANSFER_TOKEN_SALT=

# ------------------------------------------------------------
# WEBHOOK — On-Demand Revalidation ke Next.js
# Di-generate saat build. Nilai REVALIDATION_SECRET harus
# sama persis dengan yang di .env Next.js nanti.
# ------------------------------------------------------------

NEXTJS_REVALIDATION_URL=https://news.jobenapp.cloud/api/revalidate
REVALIDATION_SECRET=

# ------------------------------------------------------------
# RUNTIME
# Gunakan development selama di Replit, ganti production saat deploy ke cPanel
# ------------------------------------------------------------

NODE_ENV=development
