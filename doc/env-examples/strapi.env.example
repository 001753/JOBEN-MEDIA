# ============================================================
# JOBEN NEWS — Strapi Backend
# Salin file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke GitHub
# ============================================================

# ------------------------------------------------------------
# CLOUDFLARE R2 — Media Storage
# Panduan mendapatkan nilai ini:
#   1. Login ke https://dash.cloudflare.com
#   2. Klik menu "R2 Object Storage" di sidebar kiri
#
# ACCOUNT_ID:
#   Lihat di pojok kanan bawah halaman R2, atau di
#   URL dashboard: dash.cloudflare.com/<ACCOUNT_ID>/r2
#
# ACCESS_KEY_ID & SECRET_ACCESS_KEY:
#   R2 → Manage R2 API Tokens → Create API Token
#   Pilih permission: Object Read & Write
#   Catat Access Key ID dan Secret Access Key yang muncul
#   (Secret hanya tampil sekali — simpan baik-baik)
#
# ENDPOINT:
#   Format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   Ganti <ACCOUNT_ID> dengan Account ID Cloudflare Anda
#
# BUCKET_NAME:
#   Nama bucket yang sudah dibuat di R2
#   Contoh: joben-news-media
#
# PUBLIC_URL:
#   URL publik untuk mengakses file dari browser
#   Ada dua opsi:
#   a) Custom domain (direkomendasikan):
#      Tambahkan custom domain di R2 → nama bucket → Settings → Custom Domains
#      Contoh: https://media.news.jobenapp.cloud
#   b) URL R2.dev bawaan (hanya untuk development):
#      Aktifkan di R2 → nama bucket → Settings → Public Access
#      Contoh: https://pub-xxxxxxxxxxxx.r2.dev
# ------------------------------------------------------------

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET_NAME=joben-news-media
R2_PUBLIC_URL=https://media.news.jobenapp.cloud

# ------------------------------------------------------------
# DATABASE — PostgreSQL cPanel
# Isi sesuai yang dibuat di cPanel > PostgreSQL Databases
# Format nama di cPanel biasanya: cpaneluser_namadb
# ------------------------------------------------------------

DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_SSL=false

# ------------------------------------------------------------
# STRAPI SECURITY KEYS
# Generate masing-masing dengan perintah berikut di terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Jalankan perintah itu 5 kali untuk 5 nilai berbeda di bawah
# JANGAN pakai nilai yang sama untuk lebih dari satu key
# ------------------------------------------------------------

APP_KEYS=key1base64,key2base64,key3base64,key4base64
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
JWT_SECRET=
TRANSFER_TOKEN_SALT=

# ------------------------------------------------------------
# WEBHOOK — On-Demand Revalidation ke Next.js
# NEXTJS_REVALIDATION_URL: URL endpoint revalidate di Next.js
# REVALIDATION_SECRET: string acak panjang, HARUS SAMA
#   dengan nilai REVALIDATION_SECRET di .env Next.js
# Generate dengan:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ------------------------------------------------------------

NEXTJS_REVALIDATION_URL=https://news.jobenapp.cloud/api/revalidate
REVALIDATION_SECRET=

# ------------------------------------------------------------
# RUNTIME
# ------------------------------------------------------------

NODE_ENV=production
