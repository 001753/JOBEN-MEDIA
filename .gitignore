# ── Dependencies ─────────────────────────────────────────────
node_modules/

# ── Build outputs ──────────────────────────────────────────────
# CATATAN: build/ (Strapi admin) dan frontend/.next/ SENGAJA TIDAK
# di-ignore — build dilakukan di Replit, hasil build di-commit &
# di-push ke GitHub, lalu cPanel tinggal `git pull` + restart TANPA
# perlu build ulang di cPanel (menghindari limit resource shared hosting).
# Lihat doc/CPANEL_DEPLOY_CHECKLIST.md §5.
dist/
.strapi/
.cache/
frontend/.next/cache/

# ── Environment variables — JANGAN commit ke GitHub ───────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.development
# .env.example BOLEH di-commit (tidak ada nilai sensitif)

# ── Database lokal (SQLite dev) ───────────────────────────────
.tmp/
*.db
*.sqlite

# ── Upload lokal (media di Cloudflare R2, bukan di repo) ─────
public/uploads/

# ── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
._*

