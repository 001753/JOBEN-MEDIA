# ====================================================
# JOBEN NEWS AI AGENT — Environment Variables
# Salin file ini ke .env dan isi semua nilai
# JANGAN commit .env ke git!
# ====================================================

# === STRAPI CMS ===
STRAPI_API_URL=https://cms.news.jobenapp.cloud
STRAPI_API_TOKEN=your_strapi_api_token_here

# === CLOUDFLARE R2 STORAGE ===
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=joben-news
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# === GEMINI API KEYS (isi semua yang tersedia, min 1 max 15+) ===
GEMINI_KEY_01=AIzaSy...
GEMINI_KEY_02=AIzaSy...
GEMINI_KEY_03=AIzaSy...
GEMINI_KEY_04=AIzaSy...
GEMINI_KEY_05=AIzaSy...
GEMINI_KEY_06=AIzaSy...
GEMINI_KEY_07=AIzaSy...
GEMINI_KEY_08=AIzaSy...
GEMINI_KEY_09=AIzaSy...
GEMINI_KEY_10=AIzaSy...
GEMINI_KEY_11=AIzaSy...
GEMINI_KEY_12=AIzaSy...
GEMINI_KEY_13=AIzaSy...
GEMINI_KEY_14=AIzaSy...
GEMINI_KEY_15=AIzaSy...

# === GEMINI CONFIG (opsional, ada default) ===
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002
GEMINI_DAILY_LIMIT_PER_KEY=1500
GEMINI_COOLDOWN_MS=60000
GEMINI_ERROR_STREAK=5
GEMINI_DISABLE_MINUTES=30

# === NEXT.JS ISR REVALIDATION ===
NEXTJS_REVALIDATION_URL=https://news.jobenapp.cloud/api/revalidate
NEXTJS_REVALIDATION_SECRET=your_revalidation_secret_here

# === TELEGRAM BOT ===
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_ADMIN_CHAT_ID=123456789
TELEGRAM_CHANNEL_CHAT_ID=  # Opsional — untuk Fase 3

# === DASHBOARD ===
DASHBOARD_PORT=4000
DASHBOARD_JWT_SECRET=minimum_32_characters_random_string_here
DASHBOARD_ADMIN_USERNAME=admin
DASHBOARD_ADMIN_PASSWORD_HASH=  # Generate dengan: node -e "const b=require('bcryptjs');b.hash('password',12).then(console.log)"

# === RSS READER (opsional) ===
RSS_CONCURRENCY=5
RSS_TIMEOUT_MS=15000
RSS_MIN_SNIPPET=100

# === GENERAL ===
NODE_ENV=production
TZ=Asia/Jakarta
LOG_LEVEL=info
# LOG_LEVEL options: error | warn | info | debug
