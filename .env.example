# ============================================================
# JOBEN NEWS — Strapi .env.example
# Salin file ini menjadi .env dan isi nilainya
# File ini AMAN di-commit ke GitHub (tanpa nilai sensitif)
# ============================================================

HOST=0.0.0.0
PORT=1337
PUBLIC_URL=https://cms.news.jobenapp.cloud

# --- Strapi Security Keys ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
JWT_SECRET=
TRANSFER_TOKEN_SALT=

# --- Database ---
# Development (Replit): gunakan sqlite
# Production (cPanel): gunakan postgres
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# DATABASE_CLIENT=postgres
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432
# DATABASE_NAME=cpaneluser_namadb
# DATABASE_USERNAME=cpaneluser_namauser
# DATABASE_PASSWORD=
# DATABASE_SSL=false

# --- Cloudflare R2 ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET_NAME=joben-news
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# --- Webhook on-demand revalidation ke Next.js ---
NEXTJS_REVALIDATION_URL=https://news.jobenapp.cloud/api/revalidate
REVALIDATION_SECRET=

# --- Runtime ---
NODE_ENV=development
